# .env.example
# Copy this to .env and fill in your values. Never commit .env to git.

# ── LLM (Groq - FREE) ─────────────────────────────────────────────────────
# Sign up free at: https://console.groq.com
# No credit card required. Generous free tier.
GROQ_API_KEY=gsk_...

# ── Database ──────────────────────────────────────────────────────────────
# SQLite (default, zero-setup — good for demo)
DATABASE_URL=sqlite:///./job_agent.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/job_agent

DB_ECHO=false

# ── ATS Credentials ───────────────────────────────────────────────────────
WORKDAY_EMAIL=your@email.com
WORKDAY_PASSWORD=yourpassword

GREENHOUSE_EMAIL=your@email.com
GREENHOUSE_PASSWORD=yourpassword

LEVER_EMAIL=your@email.com
LEVER_PASSWORD=yourpassword

# ── Browser ───────────────────────────────────────────────────────────────
HEADLESS=false   # set true for server / CI runs
